# ============================================
# Pookies AI Zone - Root .gitignore
# ============================================

# ── IDE & Editors ──
.idea/
.vscode/
*.swp
*.swo

# ── OS Files ──
.DS_Store
Thumbs.db
nul

# ── Dependencies ──
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# ── Environment & Secrets ──
.env
.env.local
.env.*.local
*token.json*
*credentials.json*
*.pem

# ── Python ──
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
.pytest_cache/
.coverage
htmlcov/

# ── Expo / React Native ──
.expo/
.metro-cache/
dist/
web-build/
android/app/build/
ios/Pods/
ios/build/

# ── Build Artifacts ──
/build
*.tsbuildinfo
.cache/

# ── Archives & Binaries ──
# ── APK / AAB Binaries ──
*.apk
*.aab
*.ipa

# ── Archives & Binaries ──
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# ── Logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb
*.log

# ── Deployment ──
.vercel
next-env.d.ts
/.next/
/out/

# ── Dev Tools ──
chainlit.md
.chainlit
.ipynb_checkpoints/
.ac
android-sdk/

# ============================================
# Project-specific: Junk at root level
# (One-off scripts, data dumps, temp files)
# ============================================
/data/
/icon-data/
/icon-fixes.js
/icon-audit-plan.js
/scripts/
/.planning/
/package.json
/package-lock.json
/tsconfig.json
/README.md
/ui-ux-pro-max/

# ── Inside pookies-ai-zone ──
pookies-ai-zone/memory/
pookies-ai-zone/test_reports/
pookies-ai-zone/test_result.md
pookies-ai-zone/tools-data.json
pookies-ai-zone/design_guidelines.json
pookies-ai-zone/enriched-seed-data.ts
pookies-ai-zone/.emergent/

# ── One-off utility scripts ──
pookies-ai-zone/run-icon-update.js
pookies-ai-zone/tool_icon_updater.js
pookies-ai-zone/update-seed-file.js
pookies-ai-zone/update_tool_icons.py
pookies-ai-zone/enrich-tool-data.js
pookies-ai-zone/fix-tools.js

# ── Agent skill data (local only) ──
.agent/
