{
  "name": "ai-tools-icons",
  "version": "1.0.0",
  "description": "Icon management for AI Tools Directory",
  "scripts": {
    "fix:icons": "node scripts/fix-icons.js",
    "validate:icons": "node scripts/validate-icons.js",
    "validate:icons:check": "node scripts/validate-icons.js --check",
