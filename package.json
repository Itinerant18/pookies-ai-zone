    "update:icons": "node -e \"require('./convex/iconUpdates.ts').updateToolsIcons\""
  },
  "dependencies": {
    "expo": "^54.0.33"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}
